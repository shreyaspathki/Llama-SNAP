# Copy to .env and fill values. Do NOT commit your real .env.

# Local fine-tuned model
LOCAL_MODEL_PATH=/path/to/llama3.2-3b-instruct
LOCAL_ADAPTER_PATH=/path/to/model_artifacts/llama-lora-v2

# Ollama (optional fallback)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_S=120
OLLAMA_CONNECT_TIMEOUT_S=2

# Groq fallback (server-side keys)
# Option A: single key
GROQ_API_KEY=

# Option B: multiple keys (comma-separated)
GROQ_API_KEYS=

# Groq model to use
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_BASE_URL=https://api.groq.com/openai/v1
